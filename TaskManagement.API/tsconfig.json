{
  "compilerOptions": {
    "target": "es2021",
    "module": "commonjs",
    "lib": [ "es2021", "esnext.asynciterable" ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [ "src/**/*" ]
}